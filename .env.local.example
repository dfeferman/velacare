# Kopiere nach .env.local und trage echte Werte ein (niemals committen).
# Supabase: Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Entweder JWT-Anon-Key (legacy) oder Publishable Key aus dem Dashboard:
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Nur serverseitig — umgeht Row Level Security; niemals ins Frontend oder Git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma
# DATABASE_URL: Transaction Pooler (Settings → Database, Mode: Transaction, Port 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL: Direkt (Port 5432) — für prisma migrate
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Seed
ADMIN_SEED_EMAIL=admin@velacare.de
ADMIN_SEED_PASSWORD=change-this-before-production

# Resend — E-Mail Versand
RESEND_API_KEY=re_...
RESEND_FROM=noreply@velacare.de

# App — serverseitige Basis-URL
APP_URL=http://localhost:3001

# Cron — Absicherung der /api/cron/* Routen
CRON_SECRET=your-random-32-char-secret

# Application-level Encryption (AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=<64-char-hex-string>
